<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.doc.mapper.OaDocFileMapper">

    <resultMap type="com.ruoyi.oa.doc.domain.OaDocFile" id="OaDocFileResult">
        <id property="id" column="id"/>
        <result property="folderId" column="folder_id"/>
        <result property="name" column="name"/>
        <result property="currentVersion" column="current_version"/>
        <result property="owner" column="owner"/>
        <result property="fileType" column="file_type"/>
        <result property="size" column="size"/>
        <result property="storagePath" column="storage_path"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="folderName" column="folder_name"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaDocFileVo">
        select f.id, f.folder_id, fo.name as folder_name, f.name, f.current_version, f.owner, f.file_type, f.size,
               f.storage_path, f.status, f.tenant_id, f.create_by, f.create_time, f.update_by, f.update_time, f.remark
        from oa_doc_file f
        left join oa_doc_folder fo on fo.id = f.folder_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaDocFileResult">
        <include refid="selectOaDocFileVo"/>
        where f.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.doc.domain.OaDocFile" resultMap="OaDocFileResult">
        <include refid="selectOaDocFileVo"/>
        <where>
            and f.status = 0
            <if test="folderId != null">and f.folder_id = #{folderId}</if>
            <if test="name != null and name != ''">and f.name like concat('%', #{name}, '%')</if>
            <if test="fileType != null and fileType != ''">and f.file_type = #{fileType}</if>
            <if test="owner != null">and f.owner = #{owner}</if>
        </where>
        order by f.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.doc.domain.OaDocFile" useGeneratedKeys="true" keyProperty="id">
        insert into oa_doc_file
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="folderId != null">folder_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="currentVersion != null">current_version,</if>
            <if test="owner != null">owner,</if>
            <if test="fileType != null and fileType != ''">file_type,</if>
            <if test="size != null">size,</if>
            <if test="storagePath != null and storagePath != ''">storage_path,</if>
            <if test="status != null">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="folderId != null">#{folderId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="currentVersion != null">#{currentVersion},</if>
            <if test="owner != null">#{owner},</if>
            <if test="fileType != null and fileType != ''">#{fileType},</if>
            <if test="size != null">#{size},</if>
            <if test="storagePath != null and storagePath != ''">#{storagePath},</if>
            <if test="status != null">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.doc.domain.OaDocFile">
        update oa_doc_file
        <set>
            <if test="folderId != null">folder_id = #{folderId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="currentVersion != null">current_version = #{currentVersion},</if>
            <if test="fileType != null and fileType != ''">file_type = #{fileType},</if>
            <if test="size != null">size = #{size},</if>
            <if test="storagePath != null and storagePath != ''">storage_path = #{storagePath},</if>
            <if test="status != null">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_doc_file where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_doc_file where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByFolderId" parameterType="Long">
        delete from oa_doc_file where folder_id = #{folderId}
    </delete>

    <select id="search" parameterType="com.ruoyi.oa.doc.domain.OaDocFile" resultMap="OaDocFileResult">
        <include refid="selectOaDocFileVo"/>
        <where>
            and f.status = 0
            <if test="name != null and name != ''">and f.name like concat('%', #{name}, '%')</if>
        </where>
        order by f.create_time desc
    </select>

</mapper>

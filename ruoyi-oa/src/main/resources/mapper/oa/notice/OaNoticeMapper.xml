<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.notice.mapper.OaNoticeMapper">

    <resultMap type="com.ruoyi.oa.notice.domain.OaNotice" id="OaNoticeResult">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeIds" column="scope_ids"/>
        <result property="needConfirm" column="need_confirm"/>
        <result property="top" column="top"/>
        <result property="status" column="status"/>
        <result property="expireTime" column="expire_time"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaNoticeVo">
        select n.id, n.category_id, c.name as category_name, n.title, n.content, n.scope_type, n.scope_ids,
               n.need_confirm, n.top, n.status, n.expire_time, n.tenant_id, n.create_by, n.create_time,
               n.update_by, n.update_time, n.remark
        from oa_notice n
        left join oa_notice_category c on c.id = n.category_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaNoticeResult">
        <include refid="selectOaNoticeVo"/>
        where n.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.notice.domain.OaNotice" resultMap="OaNoticeResult">
        <include refid="selectOaNoticeVo"/>
        <where>
            <if test="title != null and title != ''">and n.title like concat('%', #{title}, '%')</if>
            <if test="categoryId != null">and n.category_id = #{categoryId}</if>
            <if test="status != null">and n.status = #{status}</if>
            <if test="top != null">and n.top = #{top}</if>
            <if test="scopeType != null and scopeType != ''">and n.scope_type = #{scopeType}</if>
        </where>
        order by n.top desc, n.create_time desc
    </select>

    <select id="selectVisibleList" parameterType="com.ruoyi.oa.notice.domain.OaNotice" resultMap="OaNoticeResult">
        <include refid="selectOaNoticeVo"/>
        <where>
            and n.status = 1
            and (n.expire_time is null or n.expire_time &gt; sysdate())
            <if test="title != null and title != ''">and n.title like concat('%', #{title}, '%')</if>
            <if test="categoryId != null">and n.category_id = #{categoryId}</if>
        </where>
        order by n.top desc, n.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.notice.domain.OaNotice" useGeneratedKeys="true" keyProperty="id">
        insert into oa_notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="scopeType != null and scopeType != ''">scope_type,</if>
            <if test="scopeIds != null and scopeIds != ''">scope_ids,</if>
            <if test="needConfirm != null">need_confirm,</if>
            <if test="top != null">top,</if>
            <if test="status != null">status,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="scopeType != null and scopeType != ''">#{scopeType},</if>
            <if test="scopeIds != null and scopeIds != ''">#{scopeIds},</if>
            <if test="needConfirm != null">#{needConfirm},</if>
            <if test="top != null">#{top},</if>
            <if test="status != null">#{status},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.notice.domain.OaNotice">
        update oa_notice
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="scopeType != null and scopeType != ''">scope_type = #{scopeType},</if>
            <if test="scopeIds != null">scope_ids = #{scopeIds},</if>
            <if test="needConfirm != null">need_confirm = #{needConfirm},</if>
            <if test="top != null">top = #{top},</if>
            <if test="status != null">status = #{status},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_notice where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_notice where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="offlineById" parameterType="Long">
        update oa_notice set status = 2, update_time = sysdate() where id = #{id}
    </update>

    <select id="countTop" resultType="long">
        select count(*) from oa_notice where top = 1 and status = 1
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.knowledgebase.mapper.OaKbArticleMapper">

    <resultMap type="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" id="OaKbArticleResult">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="title" column="title"/>
        <result property="summary" column="summary"/>
        <result property="content" column="content"/>
        <result property="tags" column="tags"/>
        <result property="author" column="author"/>
        <result property="status" column="status"/>
        <result property="version" column="version"/>
        <result property="viewCount" column="view_count"/>
        <result property="likeCount" column="like_count"/>
        <result property="favoriteCount" column="favorite_count"/>
        <result property="commentCount" column="comment_count"/>
        <result property="top" column="top"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaKbArticleVo">
        select a.id, a.category_id, c.name as category_name, a.title, a.summary, a.content, a.tags, a.author,
               a.status, a.version, a.view_count, a.like_count, a.favorite_count, a.comment_count, a.top,
               a.tenant_id, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from oa_kb_article a
        left join oa_kb_category c on c.id = a.category_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaKbArticleResult">
        <include refid="selectOaKbArticleVo"/>
        where a.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" resultMap="OaKbArticleResult">
        <include refid="selectOaKbArticleVo"/>
        <where>
            <if test="title != null and title != ''">and a.title like concat('%', #{title}, '%')</if>
            <if test="categoryId != null">and a.category_id = #{categoryId}</if>
            <if test="status != null">and a.status = #{status}</if>
            <if test="author != null and author != ''">and a.author like concat('%', #{author}, '%')</if>
            <if test="tags != null and tags != ''">and a.tags like concat('%', #{tags}, '%')</if>
        </where>
        order by a.top desc, a.create_time desc
    </select>

    <select id="selectPublishedList" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" resultMap="OaKbArticleResult">
        <include refid="selectOaKbArticleVo"/>
        <where>
            and a.status = 1
            and c.status = 1
            <if test="title != null and title != ''">
                and (a.title like concat('%', #{title}, '%')
                or a.summary like concat('%', #{title}, '%')
                or a.content like concat('%', #{title}, '%')
                or a.tags like concat('%', #{title}, '%'))
            </if>
            <if test="categoryId != null">and a.category_id = #{categoryId}</if>
            <if test="author != null and author != ''">and a.author like concat('%', #{author}, '%')</if>
        </where>
        order by a.top desc, a.view_count desc, a.create_time desc
    </select>

    <select id="selectRecommendList" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" resultMap="OaKbArticleResult">
        <include refid="selectOaKbArticleVo"/>
        <where>
            and a.status = 1
            and c.status = 1
        </where>
        order by a.top desc, a.view_count desc, a.favorite_count desc, a.create_time desc
        limit 10
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" useGeneratedKeys="true" keyProperty="id">
        insert into oa_kb_article
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="summary != null and summary != ''">summary,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="tags != null and tags != ''">tags,</if>
            <if test="author != null and author != ''">author,</if>
            <if test="status != null">status,</if>
            <if test="version != null">version,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="favoriteCount != null">favorite_count,</if>
            <if test="commentCount != null">comment_count,</if>
            <if test="top != null">top,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="summary != null and summary != ''">#{summary},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="tags != null and tags != ''">#{tags},</if>
            <if test="author != null and author != ''">#{author},</if>
            <if test="status != null">#{status},</if>
            <if test="version != null">#{version},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="favoriteCount != null">#{favoriteCount},</if>
            <if test="commentCount != null">#{commentCount},</if>
            <if test="top != null">#{top},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle">
        update oa_kb_article
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="content != null">content = #{content},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="author != null and author != ''">author = #{author},</if>
            <if test="status != null">status = #{status},</if>
            <if test="version != null">version = #{version},</if>
            <if test="top != null">top = #{top},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_kb_article where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_kb_article where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="updateStatus" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle">
        update oa_kb_article
        set status = #{status}, update_time = sysdate()
        where id = #{id}
    </update>

    <update id="incrementViewCount" parameterType="Long">
        update oa_kb_article set view_count = view_count + 1 where id = #{id}
    </update>

    <update id="incrementFavoriteCount" parameterType="Long">
        update oa_kb_article set favorite_count = favorite_count + 1 where id = #{id}
    </update>

    <update id="decrementFavoriteCount" parameterType="Long">
        update oa_kb_article set favorite_count = favorite_count - 1 where id = #{id} and favorite_count &gt; 0
    </update>

    <select id="checkTitleUnique" parameterType="com.ruoyi.oa.knowledgebase.domain.OaKbArticle" resultMap="OaKbArticleResult">
        <include refid="selectOaKbArticleVo"/>
        where a.category_id = #{categoryId} and a.title = #{title} limit 1
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.message.mapper.OaMessageLogMapper">

    <resultMap type="com.ruoyi.oa.message.domain.OaMessageLog" id="OaMessageLogResult">
        <id property="id" column="id"/>
        <result property="messageId" column="message_id"/>
        <result property="channel" column="channel"/>
        <result property="request" column="request"/>
        <result property="response" column="response"/>
        <result property="status" column="status"/>
        <result property="retryCount" column="retry_count"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectOaMessageLogVo">
        select id, message_id, channel, request, response, status, retry_count, tenant_id, create_time
        from oa_message_log
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaMessageLogResult">
        <include refid="selectOaMessageLogVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.message.domain.OaMessageLog" resultMap="OaMessageLogResult">
        <include refid="selectOaMessageLogVo"/>
        <where>
            <if test="messageId != null">and message_id = #{messageId}</if>
            <if test="channel != null and channel != ''">and channel = #{channel}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.message.domain.OaMessageLog" useGeneratedKeys="true" keyProperty="id">
        insert into oa_message_log (message_id, channel, request, response, status, retry_count, tenant_id, create_time)
        values (#{messageId}, #{channel}, #{request}, #{response}, #{status}, #{retryCount}, #{tenantId}, #{createTime})
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.message.domain.OaMessageLog">
        update oa_message_log
        <set>
            <if test="channel != null and channel != ''">channel = #{channel},</if>
            <if test="request != null">request = #{request},</if>
            <if test="response != null">response = #{response},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="retryCount != null">retry_count = #{retryCount},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteByMessageIds">
        delete from oa_message_log where message_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

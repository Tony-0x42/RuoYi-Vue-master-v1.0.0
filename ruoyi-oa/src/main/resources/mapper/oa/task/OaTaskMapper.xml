<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.task.mapper.OaTaskMapper">

    <resultMap type="com.ruoyi.oa.task.domain.OaTask" id="OaTaskResult">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="ownerId" column="owner_id"/>
        <result property="ownerName" column="owner_name"/>
        <result property="projectId" column="project_id"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="progress" column="progress"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaTaskVo">
        select t.id, t.title, t.description, t.owner_id, u.nick_name as owner_name, t.project_id,
               t.priority, t.status, t.start_time, t.end_time, t.progress, t.tenant_id,
               t.create_by, t.create_time, t.update_by, t.update_time, t.remark
        from oa_task t
        left join sys_user u on u.user_id = t.owner_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaTaskResult">
        <include refid="selectOaTaskVo"/>
        where t.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.task.domain.OaTask" resultMap="OaTaskResult">
        <include refid="selectOaTaskVo"/>
        <where>
            <if test="title != null and title != ''">and t.title like concat('%', #{title}, '%')</if>
            <if test="ownerId != null">and t.owner_id = #{ownerId}</if>
            <if test="status != null">and t.status = #{status}</if>
            <if test="priority != null and priority != ''">and t.priority = #{priority}</if>
            <if test="projectId != null">and t.project_id = #{projectId}</if>
        </where>
        order by t.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.task.domain.OaTask" useGeneratedKeys="true" keyProperty="id">
        insert into oa_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="ownerId != null">owner_id,</if>
            <if test="projectId != null">project_id,</if>
            <if test="priority != null and priority != ''">priority,</if>
            <if test="status != null">status,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="progress != null">progress,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="ownerId != null">#{ownerId},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="priority != null and priority != ''">#{priority},</if>
            <if test="status != null">#{status},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="progress != null">#{progress},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.task.domain.OaTask">
        update oa_task
        <set>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="priority != null and priority != ''">priority = #{priority},</if>
            <if test="status != null">status = #{status},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_task where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_task where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countByStatus" parameterType="Integer" resultType="long">
        select count(*) from oa_task
        <where>
            <if test="status != null">and status = #{status}</if>
        </where>
    </select>

    <select id="countAll" resultType="long">
        select count(*) from oa_task
    </select>

</mapper>

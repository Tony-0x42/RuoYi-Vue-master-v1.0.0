<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.task.mapper.OaTaskCommentMapper">

    <resultMap type="com.ruoyi.oa.task.domain.OaTaskComment" id="OaTaskCommentResult">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
        <result property="tenantId" column="tenant_id"/>
    </resultMap>

    <select id="selectByTaskId" parameterType="Long" resultMap="OaTaskCommentResult">
        select c.id, c.task_id, c.user_id, u.nick_name as user_name, c.content, c.create_time, c.tenant_id
        from oa_task_comment c
        left join sys_user u on u.user_id = c.user_id
        where c.task_id = #{taskId}
        order by c.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.task.domain.OaTaskComment" useGeneratedKeys="true" keyProperty="id">
        insert into oa_task_comment (task_id, user_id, content, tenant_id, create_time)
        values (#{taskId}, #{userId}, #{content}, #{tenantId}, sysdate())
    </insert>

    <delete id="deleteByTaskId" parameterType="Long">
        delete from oa_task_comment where task_id = #{taskId}
    </delete>

</mapper>

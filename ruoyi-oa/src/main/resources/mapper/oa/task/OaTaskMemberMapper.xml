<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.task.mapper.OaTaskMemberMapper">

    <resultMap type="com.ruoyi.oa.task.domain.OaTaskMember" id="OaTaskMemberResult">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="userId" column="user_id"/>
        <result property="role" column="role"/>
        <result property="userName" column="user_name"/>
        <result property="tenantId" column="tenant_id"/>
    </resultMap>

    <select id="selectByTaskId" parameterType="Long" resultMap="OaTaskMemberResult">
        select m.id, m.task_id, m.user_id, m.role, u.nick_name as user_name, m.tenant_id
        from oa_task_member m
        left join sys_user u on u.user_id = m.user_id
        where m.task_id = #{taskId}
    </select>

    <insert id="insertBatch">
        insert into oa_task_member (task_id, user_id, role, tenant_id) values
        <foreach collection="list" item="item" separator=",">
            (#{item.taskId}, #{item.userId}, #{item.role}, #{item.tenantId})
        </foreach>
    </insert>

    <delete id="deleteByTaskId" parameterType="Long">
        delete from oa_task_member where task_id = #{taskId}
    </delete>

    <delete id="deleteByTaskIds">
        delete from oa_task_member where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

</mapper>

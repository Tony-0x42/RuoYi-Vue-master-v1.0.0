<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.meeting.mapper.OaMeetingRoomMapper">

    <resultMap type="com.ruoyi.oa.meeting.domain.OaMeetingRoom" id="OaMeetingRoomResult">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="location" column="location"/>
        <result property="capacity" column="capacity"/>
        <result property="devices" column="devices"/>
        <result property="status" column="status"/>
        <result property="picUrl" column="pic_url"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaMeetingRoomVo">
        select id, code, name, location, capacity, devices, status, pic_url, tenant_id,
               create_by, create_time, update_by, update_time, remark
        from oa_meeting_room
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaMeetingRoomResult">
        <include refid="selectOaMeetingRoomVo"/>
        where id = #{id}
    </select>

    <select id="selectByCode" parameterType="String" resultMap="OaMeetingRoomResult">
        <include refid="selectOaMeetingRoomVo"/>
        where code = #{code}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.meeting.domain.OaMeetingRoom" resultMap="OaMeetingRoomResult">
        <include refid="selectOaMeetingRoomVo"/>
        <where>
            <if test="code != null and code != ''">and code = #{code}</if>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="location != null and location != ''">and location like concat('%', #{location}, '%')</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAvailableList" parameterType="com.ruoyi.oa.meeting.domain.OaMeetingRoom" resultMap="OaMeetingRoomResult">
        <include refid="selectOaMeetingRoomVo"/>
        where status = 1
        <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.meeting.domain.OaMeetingRoom" useGeneratedKeys="true" keyProperty="id">
        insert into oa_meeting_room
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">code,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="capacity != null">capacity,</if>
            <if test="devices != null and devices != ''">devices,</if>
            <if test="status != null">status,</if>
            <if test="picUrl != null and picUrl != ''">pic_url,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">#{code},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="capacity != null">#{capacity},</if>
            <if test="devices != null and devices != ''">#{devices},</if>
            <if test="status != null">#{status},</if>
            <if test="picUrl != null and picUrl != ''">#{picUrl},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.meeting.domain.OaMeetingRoom">
        update oa_meeting_room
        <set>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="location != null">location = #{location},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="devices != null">devices = #{devices},</if>
            <if test="status != null">status = #{status},</if>
            <if test="picUrl != null">pic_url = #{picUrl},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_meeting_room where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_meeting_room where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

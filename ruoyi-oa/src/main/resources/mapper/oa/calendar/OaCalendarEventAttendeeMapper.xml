<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.calendar.mapper.OaCalendarEventAttendeeMapper">

    <resultMap type="OaCalendarEventAttendee" id="OaCalendarEventAttendeeResult">
        <result property="id"       column="id"        />
        <result property="eventId"  column="event_id"  />
        <result property="userId"   column="user_id"   />
        <result property="status"   column="status"    />
        <result property="tenantId" column="tenant_id" />
    </resultMap>

    <sql id="selectOaCalendarEventAttendeeVo">
        select id, event_id, user_id, status, tenant_id
        from oa_calendar_event_attendee
    </sql>

    <select id="selectByEventId" parameterType="Long" resultMap="OaCalendarEventAttendeeResult">
        <include refid="selectOaCalendarEventAttendeeVo"/>
        where event_id = #{eventId}
    </select>

    <insert id="insertBatch">
        insert into oa_calendar_event_attendee (event_id, user_id, status, tenant_id) values
        <foreach item="item" collection="list" separator=",">
            (#{item.eventId}, #{item.userId}, #{item.status}, #{item.tenantId})
        </foreach>
    </insert>

    <delete id="deleteByEventId" parameterType="Long">
        delete from oa_calendar_event_attendee where event_id = #{eventId}
    </delete>

</mapper>

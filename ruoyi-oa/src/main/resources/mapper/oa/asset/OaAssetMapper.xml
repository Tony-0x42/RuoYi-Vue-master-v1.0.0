<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.asset.mapper.OaAssetMapper">

    <resultMap type="com.ruoyi.oa.asset.domain.OaAsset" id="OaAssetResult">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="model" column="model"/>
        <result property="spec" column="spec"/>
        <result property="purchaseDate" column="purchase_date"/>
        <result property="value" column="value"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="deptId" column="dept_id"/>
        <result property="deptName" column="dept_name"/>
        <result property="location" column="location"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaAssetVo">
        select a.id, a.code, a.name, a.category_id, c.name as category_name, a.model, a.spec, a.purchase_date,
               a.value, a.user_id, a.user_name, a.dept_id, a.dept_name, a.location, a.status,
               a.tenant_id, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from oa_asset a
        left join oa_asset_category c on c.id = a.category_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaAssetResult">
        <include refid="selectOaAssetVo"/>
        where a.id = #{id}
    </select>

    <select id="selectByCode" parameterType="String" resultMap="OaAssetResult">
        <include refid="selectOaAssetVo"/>
        where a.code = #{code}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.asset.domain.OaAsset" resultMap="OaAssetResult">
        <include refid="selectOaAssetVo"/>
        <where>
            <if test="code != null and code != ''">and a.code like concat('%', #{code}, '%')</if>
            <if test="name != null and name != ''">and a.name like concat('%', #{name}, '%')</if>
            <if test="categoryId != null">and a.category_id = #{categoryId}</if>
            <if test="status != null">and a.status = #{status}</if>
            <if test="userId != null">and a.user_id = #{userId}</if>
            <if test="deptId != null">and a.dept_id = #{deptId}</if>
            <if test="location != null and location != ''">and a.location like concat('%', #{location}, '%')</if>
            <if test="model != null and model != ''">and a.model like concat('%', #{model}, '%')</if>
        </where>
        order by a.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.asset.domain.OaAsset" useGeneratedKeys="true" keyProperty="id">
        insert into oa_asset
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">code,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="model != null and model != ''">model,</if>
            <if test="spec != null and spec != ''">spec,</if>
            <if test="purchaseDate != null">purchase_date,</if>
            <if test="value != null">value,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="status != null">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">#{code},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="model != null and model != ''">#{model},</if>
            <if test="spec != null and spec != ''">#{spec},</if>
            <if test="purchaseDate != null">#{purchaseDate},</if>
            <if test="value != null">#{value},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="status != null">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.asset.domain.OaAsset">
        update oa_asset
        <set>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="model != null">model = #{model},</if>
            <if test="spec != null">spec = #{spec},</if>
            <if test="purchaseDate != null">purchase_date = #{purchaseDate},</if>
            <if test="value != null">value = #{value},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="location != null">location = #{location},</if>
            <if test="status != null">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_asset where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_asset where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countAll" resultType="long">
        select count(*) from oa_asset
    </select>

    <select id="countByStatus" parameterType="Integer" resultType="long">
        select count(*) from oa_asset where status = #{status}
    </select>

    <select id="sumValue" resultType="java.math.BigDecimal">
        select ifnull(sum(value), 0) from oa_asset
    </select>

    <select id="countByCategory" resultType="java.util.HashMap">
        select c.name as categoryName, count(*) as count
        from oa_asset a
        left join oa_asset_category c on c.id = a.category_id
        group by c.name
    </select>

</mapper>

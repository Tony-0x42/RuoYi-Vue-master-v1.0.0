<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.asset.mapper.OaAssetRepairMapper">

    <resultMap type="com.ruoyi.oa.asset.domain.OaAssetRepair" id="OaAssetRepairResult">
        <id property="id" column="id"/>
        <result property="assetId" column="asset_id"/>
        <result property="reason" column="reason"/>
        <result property="cost" column="cost"/>
        <result property="vendor" column="vendor"/>
        <result property="repairTime" column="repair_time"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaAssetRepairVo">
        select id, asset_id, reason, cost, vendor, repair_time, status, tenant_id,
               create_by, create_time, update_by, update_time, remark
        from oa_asset_repair
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaAssetRepairResult">
        <include refid="selectOaAssetRepairVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.asset.domain.OaAssetRepair" resultMap="OaAssetRepairResult">
        <include refid="selectOaAssetRepairVo"/>
        <where>
            <if test="assetId != null">and asset_id = #{assetId}</if>
            <if test="status != null">and status = #{status}</if>
            <if test="vendor != null and vendor != ''">and vendor like concat('%', #{vendor}, '%')</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectListByAssetId" parameterType="Long" resultMap="OaAssetRepairResult">
        <include refid="selectOaAssetRepairVo"/>
        where asset_id = #{assetId}
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.asset.domain.OaAssetRepair" useGeneratedKeys="true" keyProperty="id">
        insert into oa_asset_repair
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="assetId != null">asset_id,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="cost != null">cost,</if>
            <if test="vendor != null and vendor != ''">vendor,</if>
            <if test="repairTime != null">repair_time,</if>
            <if test="status != null">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="assetId != null">#{assetId},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="cost != null">#{cost},</if>
            <if test="vendor != null and vendor != ''">#{vendor},</if>
            <if test="repairTime != null">#{repairTime},</if>
            <if test="status != null">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.asset.domain.OaAssetRepair">
        update oa_asset_repair
        <set>
            <if test="assetId != null">asset_id = #{assetId},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="cost != null">cost = #{cost},</if>
            <if test="vendor != null">vendor = #{vendor},</if>
            <if test="repairTime != null">repair_time = #{repairTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_asset_repair where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_asset_repair where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.asset.mapper.OaAssetScrapMapper">

    <resultMap type="com.ruoyi.oa.asset.domain.OaAssetScrap" id="OaAssetScrapResult">
        <id property="id" column="id"/>
        <result property="assetId" column="asset_id"/>
        <result property="reason" column="reason"/>
        <result property="disposalMethod" column="disposal_method"/>
        <result property="processInstanceId" column="process_instance_id"/>
        <result property="scrapTime" column="scrap_time"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaAssetScrapVo">
        select id, asset_id, reason, disposal_method, process_instance_id, scrap_time, tenant_id,
               create_by, create_time, update_by, update_time, remark
        from oa_asset_scrap
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaAssetScrapResult">
        <include refid="selectOaAssetScrapVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.asset.domain.OaAssetScrap" resultMap="OaAssetScrapResult">
        <include refid="selectOaAssetScrapVo"/>
        <where>
            <if test="assetId != null">and asset_id = #{assetId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectListByAssetId" parameterType="Long" resultMap="OaAssetScrapResult">
        <include refid="selectOaAssetScrapVo"/>
        where asset_id = #{assetId}
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.asset.domain.OaAssetScrap" useGeneratedKeys="true" keyProperty="id">
        insert into oa_asset_scrap
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="assetId != null">asset_id,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="disposalMethod != null and disposalMethod != ''">disposal_method,</if>
            <if test="processInstanceId != null and processInstanceId != ''">process_instance_id,</if>
            <if test="scrapTime != null">scrap_time,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="assetId != null">#{assetId},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="disposalMethod != null and disposalMethod != ''">#{disposalMethod},</if>
            <if test="processInstanceId != null and processInstanceId != ''">#{processInstanceId},</if>
            <if test="scrapTime != null">#{scrapTime},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.asset.domain.OaAssetScrap">
        update oa_asset_scrap
        <set>
            <if test="assetId != null">asset_id = #{assetId},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="disposalMethod != null">disposal_method = #{disposalMethod},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="scrapTime != null">scrap_time = #{scrapTime},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_asset_scrap where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_asset_scrap where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

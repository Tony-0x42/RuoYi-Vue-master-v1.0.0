<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.expense.mapper.OaExpenseBudgetMapper">

    <resultMap type="com.ruoyi.oa.expense.domain.OaExpenseBudget" id="OaExpenseBudgetResult">
        <id property="id" column="id"/>
        <result property="deptId" column="dept_id"/>
        <result property="projectId" column="project_id"/>
        <result property="itemId" column="item_id"/>
        <result property="year" column="year"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="usedAmount" column="used_amount"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaExpenseBudgetVo">
        select id, dept_id, project_id, item_id, year, total_amount, used_amount, status, tenant_id,
               create_by, create_time, update_by, update_time, remark
        from oa_expense_budget
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaExpenseBudgetResult">
        <include refid="selectOaExpenseBudgetVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.expense.domain.OaExpenseBudget" resultMap="OaExpenseBudgetResult">
        <include refid="selectOaExpenseBudgetVo"/>
        <where>
            <if test="deptId != null">and dept_id = #{deptId}</if>
            <if test="projectId != null">and project_id = #{projectId}</if>
            <if test="itemId != null">and item_id = #{itemId}</if>
            <if test="year != null">and year = #{year}</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by year desc, create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.expense.domain.OaExpenseBudget" useGeneratedKeys="true" keyProperty="id">
        insert into oa_expense_budget
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptId != null">dept_id,</if>
            <if test="projectId != null">project_id,</if>
            <if test="itemId != null">item_id,</if>
            <if test="year != null">year,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="usedAmount != null">used_amount,</if>
            <if test="status != null">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptId != null">#{deptId},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="itemId != null">#{itemId},</if>
            <if test="year != null">#{year},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="usedAmount != null">#{usedAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.expense.domain.OaExpenseBudget">
        update oa_expense_budget
        <set>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="itemId != null">item_id = #{itemId},</if>
            <if test="year != null">year = #{year},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="usedAmount != null">used_amount = #{usedAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_expense_budget where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_expense_budget where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="occupyAmount" parameterType="com.ruoyi.oa.expense.domain.OaExpenseBudget">
        update oa_expense_budget
        set used_amount = used_amount + #{usedAmount},
            update_time = sysdate()
        where id = #{id}
    </update>

    <update id="releaseAmount" parameterType="com.ruoyi.oa.expense.domain.OaExpenseBudget">
        update oa_expense_budget
        set used_amount = used_amount - #{usedAmount},
            update_time = sysdate()
        where id = #{id}
    </update>

</mapper>

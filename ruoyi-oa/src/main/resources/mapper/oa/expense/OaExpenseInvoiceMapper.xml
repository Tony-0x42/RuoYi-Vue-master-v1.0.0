<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.expense.mapper.OaExpenseInvoiceMapper">

    <resultMap type="com.ruoyi.oa.expense.domain.OaExpenseInvoice" id="OaExpenseInvoiceResult">
        <id property="id" column="id"/>
        <result property="invoiceCode" column="invoice_code"/>
        <result property="invoiceNo" column="invoice_no"/>
        <result property="invoiceType" column="invoice_type"/>
        <result property="amount" column="amount"/>
        <result property="tax" column="tax"/>
        <result property="invoiceDate" column="invoice_date"/>
        <result property="buyer" column="buyer"/>
        <result property="seller" column="seller"/>
        <result property="status" column="status"/>
        <result property="verifyResult" column="verify_result"/>
        <result property="imageUrl" column="image_url"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaExpenseInvoiceVo">
        select id, invoice_code, invoice_no, invoice_type, amount, tax, invoice_date, buyer, seller,
               status, verify_result, image_url, tenant_id, create_by, create_time, update_by, update_time, remark
        from oa_expense_invoice
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaExpenseInvoiceResult">
        <include refid="selectOaExpenseInvoiceVo"/>
        where id = #{id}
    </select>

    <select id="selectByCodeAndNo" parameterType="com.ruoyi.oa.expense.domain.OaExpenseInvoice" resultMap="OaExpenseInvoiceResult">
        <include refid="selectOaExpenseInvoiceVo"/>
        where invoice_code = #{invoiceCode} and invoice_no = #{invoiceNo} limit 1
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.expense.domain.OaExpenseInvoice" resultMap="OaExpenseInvoiceResult">
        <include refid="selectOaExpenseInvoiceVo"/>
        <where>
            <if test="invoiceCode != null and invoiceCode != ''">and invoice_code like concat('%', #{invoiceCode}, '%')</if>
            <if test="invoiceNo != null and invoiceNo != ''">and invoice_no like concat('%', #{invoiceNo}, '%')</if>
            <if test="invoiceType != null and invoiceType != ''">and invoice_type = #{invoiceType}</if>
            <if test="buyer != null and buyer != ''">and buyer like concat('%', #{buyer}, '%')</if>
            <if test="seller != null and seller != ''">and seller like concat('%', #{seller}, '%')</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.expense.domain.OaExpenseInvoice" useGeneratedKeys="true" keyProperty="id">
        insert into oa_expense_invoice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="invoiceCode != null and invoiceCode != ''">invoice_code,</if>
            <if test="invoiceNo != null and invoiceNo != ''">invoice_no,</if>
            <if test="invoiceType != null and invoiceType != ''">invoice_type,</if>
            <if test="amount != null">amount,</if>
            <if test="tax != null">tax,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="buyer != null and buyer != ''">buyer,</if>
            <if test="seller != null and seller != ''">seller,</if>
            <if test="status != null">status,</if>
            <if test="verifyResult != null and verifyResult != ''">verify_result,</if>
            <if test="imageUrl != null and imageUrl != ''">image_url,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="invoiceCode != null and invoiceCode != ''">#{invoiceCode},</if>
            <if test="invoiceNo != null and invoiceNo != ''">#{invoiceNo},</if>
            <if test="invoiceType != null and invoiceType != ''">#{invoiceType},</if>
            <if test="amount != null">#{amount},</if>
            <if test="tax != null">#{tax},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="buyer != null and buyer != ''">#{buyer},</if>
            <if test="seller != null and seller != ''">#{seller},</if>
            <if test="status != null">#{status},</if>
            <if test="verifyResult != null and verifyResult != ''">#{verifyResult},</if>
            <if test="imageUrl != null and imageUrl != ''">#{imageUrl},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.expense.domain.OaExpenseInvoice">
        update oa_expense_invoice
        <set>
            <if test="invoiceCode != null">invoice_code = #{invoiceCode},</if>
            <if test="invoiceNo != null">invoice_no = #{invoiceNo},</if>
            <if test="invoiceType != null">invoice_type = #{invoiceType},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="tax != null">tax = #{tax},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="buyer != null">buyer = #{buyer},</if>
            <if test="seller != null">seller = #{seller},</if>
            <if test="status != null">status = #{status},</if>
            <if test="verifyResult != null">verify_result = #{verifyResult},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_expense_invoice where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_expense_invoice where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.expense.mapper.OaExpenseReportMapper">

    <resultMap type="com.ruoyi.oa.expense.domain.OaExpenseReport" id="OaExpenseReportResult">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="deptId" column="dept_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="processInstanceId" column="process_instance_id"/>
        <result property="status" column="status"/>
        <result property="loanId" column="loan_id"/>
        <result property="offsetAmount" column="offset_amount"/>
        <result property="reason" column="reason"/>
        <result property="submitTime" column="submit_time"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaExpenseReportVo">
        select r.id, r.user_id, r.user_name, r.dept_id, r.total_amount, r.category_id, c.name as category_name,
               r.process_instance_id, r.status, r.loan_id, r.offset_amount, r.reason, r.submit_time,
               r.tenant_id, r.create_by, r.create_time, r.update_by, r.update_time, r.remark
        from oa_expense_report r
        left join oa_expense_category c on c.id = r.category_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaExpenseReportResult">
        <include refid="selectOaExpenseReportVo"/>
        where r.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.expense.domain.OaExpenseReport" resultMap="OaExpenseReportResult">
        <include refid="selectOaExpenseReportVo"/>
        <where>
            <if test="userName != null and userName != ''">and r.user_name like concat('%', #{userName}, '%')</if>
            <if test="categoryId != null">and r.category_id = #{categoryId}</if>
            <if test="status != null">and r.status = #{status}</if>
            <if test="loanId != null">and r.loan_id = #{loanId}</if>
            <if test="createBy != null and createBy != ''">and r.create_by = #{createBy}</if>
        </where>
        order by r.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.expense.domain.OaExpenseReport" useGeneratedKeys="true" keyProperty="id">
        insert into oa_expense_report
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="processInstanceId != null and processInstanceId != ''">process_instance_id,</if>
            <if test="status != null">status,</if>
            <if test="loanId != null">loan_id,</if>
            <if test="offsetAmount != null">offset_amount,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="submitTime != null">submit_time,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="processInstanceId != null and processInstanceId != ''">#{processInstanceId},</if>
            <if test="status != null">#{status},</if>
            <if test="loanId != null">#{loanId},</if>
            <if test="offsetAmount != null">#{offsetAmount},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="submitTime != null">#{submitTime},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.expense.domain.OaExpenseReport">
        update oa_expense_report
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="loanId != null">loan_id = #{loanId},</if>
            <if test="offsetAmount != null">offset_amount = #{offsetAmount},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="submitTime != null">submit_time = #{submitTime},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_expense_report where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_expense_report where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="updateStatus" parameterType="com.ruoyi.oa.expense.domain.OaExpenseReport">
        update oa_expense_report
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="submitTime != null">submit_time = #{submitTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

</mapper>

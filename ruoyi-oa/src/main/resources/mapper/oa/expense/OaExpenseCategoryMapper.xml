<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.expense.mapper.OaExpenseCategoryMapper">

    <resultMap type="com.ruoyi.oa.expense.domain.OaExpenseCategory" id="OaExpenseCategoryResult">
        <id property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="processKey" column="process_key"/>
        <result property="budgetItemId" column="budget_item_id"/>
        <result property="status" column="status"/>
        <result property="sort" column="sort"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaExpenseCategoryVo">
        select id, parent_id, name, code, process_key, budget_item_id, status, sort, tenant_id,
               create_by, create_time, update_by, update_time, remark
        from oa_expense_category
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaExpenseCategoryResult">
        <include refid="selectOaExpenseCategoryVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.expense.domain.OaExpenseCategory" resultMap="OaExpenseCategoryResult">
        <include refid="selectOaExpenseCategoryVo"/>
        <where>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="code != null and code != ''">and code = #{code}</if>
            <if test="parentId != null">and parent_id = #{parentId}</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by sort, create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.expense.domain.OaExpenseCategory" useGeneratedKeys="true" keyProperty="id">
        insert into oa_expense_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="processKey != null and processKey != ''">process_key,</if>
            <if test="budgetItemId != null">budget_item_id,</if>
            <if test="status != null">status,</if>
            <if test="sort != null">sort,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="processKey != null and processKey != ''">#{processKey},</if>
            <if test="budgetItemId != null">#{budgetItemId},</if>
            <if test="status != null">#{status},</if>
            <if test="sort != null">#{sort},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.expense.domain.OaExpenseCategory">
        update oa_expense_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="processKey != null">process_key = #{processKey},</if>
            <if test="budgetItemId != null">budget_item_id = #{budgetItemId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_expense_category where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_expense_category where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.expense.mapper.OaExpenseStandardMapper">

    <resultMap type="com.ruoyi.oa.expense.domain.OaExpenseStandard" id="OaExpenseStandardResult">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="level" column="level"/>
        <result property="city" column="city"/>
        <result property="deptId" column="dept_id"/>
        <result property="limitAmount" column="limit_amount"/>
        <result property="periodType" column="period_type"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaExpenseStandardVo">
        select s.id, s.category_id, c.name as category_name, s.level, s.city, s.dept_id, s.limit_amount,
               s.period_type, s.status, s.tenant_id, s.create_by, s.create_time, s.update_by, s.update_time, s.remark
        from oa_expense_standard s
        left join oa_expense_category c on c.id = s.category_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaExpenseStandardResult">
        <include refid="selectOaExpenseStandardVo"/>
        where s.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.expense.domain.OaExpenseStandard" resultMap="OaExpenseStandardResult">
        <include refid="selectOaExpenseStandardVo"/>
        <where>
            <if test="categoryId != null">and s.category_id = #{categoryId}</if>
            <if test="level != null and level != ''">and s.level = #{level}</if>
            <if test="city != null and city != ''">and s.city like concat('%', #{city}, '%')</if>
            <if test="deptId != null">and s.dept_id = #{deptId}</if>
            <if test="status != null">and s.status = #{status}</if>
        </where>
        order by s.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.expense.domain.OaExpenseStandard" useGeneratedKeys="true" keyProperty="id">
        insert into oa_expense_standard
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="level != null and level != ''">level,</if>
            <if test="city != null and city != ''">city,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="limitAmount != null">limit_amount,</if>
            <if test="periodType != null and periodType != ''">period_type,</if>
            <if test="status != null">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="level != null and level != ''">#{level},</if>
            <if test="city != null and city != ''">#{city},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="limitAmount != null">#{limitAmount},</if>
            <if test="periodType != null and periodType != ''">#{periodType},</if>
            <if test="status != null">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.expense.domain.OaExpenseStandard">
        update oa_expense_standard
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="level != null">level = #{level},</if>
            <if test="city != null">city = #{city},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="limitAmount != null">limit_amount = #{limitAmount},</if>
            <if test="periodType != null">period_type = #{periodType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_expense_standard where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_expense_standard where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

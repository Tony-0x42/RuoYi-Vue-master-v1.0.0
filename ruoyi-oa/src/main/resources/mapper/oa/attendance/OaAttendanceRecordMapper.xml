<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.attendance.mapper.OaAttendanceRecordMapper">

    <resultMap type="com.ruoyi.oa.attendance.domain.OaAttendanceRecord" id="OaAttendanceRecordResult">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="checkInDate" column="check_in_date"/>
        <result property="checkInTime" column="check_in_time"/>
        <result property="type" column="type"/>
        <result property="location" column="location"/>
        <result property="wifi" column="wifi"/>
        <result property="photo" column="photo"/>
        <result property="status" column="status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaAttendanceRecordVo">
        select r.id, r.user_id, u.nick_name as user_name, r.check_in_date, r.check_in_time,
               r.type, r.location, r.wifi, r.photo, r.status, r.tenant_id,
               r.create_by, r.create_time, r.remark
        from oa_attendance_record r
        left join sys_user u on u.user_id = r.user_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaAttendanceRecordResult">
        <include refid="selectOaAttendanceRecordVo"/>
        where r.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceRecord" resultMap="OaAttendanceRecordResult">
        <include refid="selectOaAttendanceRecordVo"/>
        <where>
            <if test="userId != null">and r.user_id = #{userId}</if>
            <if test="type != null and type != ''">and r.type = #{type}</if>
            <if test="status != null and status != ''">and r.status = #{status}</if>
            <if test="checkInDate != null">and r.check_in_date = #{checkInDate}</if>
            <if test="params.beginTime != null and params.beginTime != ''">and r.check_in_date &gt;= #{params.beginTime}</if>
            <if test="params.endTime != null and params.endTime != ''">and r.check_in_date &lt;= #{params.endTime}</if>
        </where>
        order by r.check_in_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceRecord" useGeneratedKeys="true" keyProperty="id">
        insert into oa_attendance_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="checkInDate != null">check_in_date,</if>
            <if test="checkInTime != null">check_in_time,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="wifi != null and wifi != ''">wifi,</if>
            <if test="photo != null and photo != ''">photo,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="checkInDate != null">#{checkInDate},</if>
            <if test="checkInTime != null">#{checkInTime},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="wifi != null and wifi != ''">#{wifi},</if>
            <if test="photo != null and photo != ''">#{photo},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceRecord">
        update oa_attendance_record
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="checkInDate != null">check_in_date = #{checkInDate},</if>
            <if test="checkInTime != null">check_in_time = #{checkInTime},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="location != null">location = #{location},</if>
            <if test="wifi != null">wifi = #{wifi},</if>
            <if test="photo != null">photo = #{photo},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_attendance_record where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_attendance_record where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countByStatus" parameterType="String" resultType="long">
        select count(*) from oa_attendance_record
        <where>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
    </select>

    <select id="countAll" resultType="long">
        select count(*) from oa_attendance_record
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.oa.attendance.mapper.OaAttendanceTripMapper">

    <resultMap type="com.ruoyi.oa.attendance.domain.OaAttendanceTrip" id="OaAttendanceTripResult">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="destination" column="destination"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="days" column="days"/>
        <result property="reason" column="reason"/>
        <result property="status" column="status"/>
        <result property="processInstanceId" column="process_instance_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOaAttendanceTripVo">
        select t.id, t.user_id, u.nick_name as user_name, t.destination, t.start_time, t.end_time,
               t.days, t.reason, t.status, t.process_instance_id, t.tenant_id,
               t.create_by, t.create_time, t.update_by, t.update_time, t.remark
        from oa_attendance_trip t
        left join sys_user u on u.user_id = t.user_id
    </sql>

    <select id="selectById" parameterType="Long" resultMap="OaAttendanceTripResult">
        <include refid="selectOaAttendanceTripVo"/>
        where t.id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceTrip" resultMap="OaAttendanceTripResult">
        <include refid="selectOaAttendanceTripVo"/>
        <where>
            <if test="userId != null">and t.user_id = #{userId}</if>
            <if test="userName != null and userName != ''">and u.nick_name like concat('%', #{userName}, '%')</if>
            <if test="destination != null and destination != ''">and t.destination like concat('%', #{destination}, '%')</if>
            <if test="status != null and status != ''">and t.status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''">and t.start_time &gt;= #{params.beginTime}</if>
            <if test="params.endTime != null and params.endTime != ''">and t.end_time &lt;= #{params.endTime}</if>
        </where>
        order by t.create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceTrip" useGeneratedKeys="true" keyProperty="id">
        insert into oa_attendance_trip
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="destination != null and destination != ''">destination,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="days != null">days,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="processInstanceId != null and processInstanceId != ''">process_instance_id,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="destination != null and destination != ''">#{destination},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="days != null">#{days},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="processInstanceId != null and processInstanceId != ''">#{processInstanceId},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.oa.attendance.domain.OaAttendanceTrip">
        update oa_attendance_trip
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="destination != null and destination != ''">destination = #{destination},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="days != null">days = #{days},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from oa_attendance_trip where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from oa_attendance_trip where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

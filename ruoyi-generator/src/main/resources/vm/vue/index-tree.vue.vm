      </el-form-item>
#elseif(($column.htmlType == "select" || $column.htmlType == "radio") && "" != $dictType)
      <el-form-item label="${comment}" prop="${column.javaField}">
        <el-select v-model="queryParams.${column.javaField}" placeholder="ŤĮ∑ťÄČśč©${comment}" clearable>
          <el-option
            v-for="dict in dict.type.${dictType}"
            :key="dict.value"
            :label="dict.label"
            :value="dict.value"
          />
        </el-select>
      </el-form-item>
#elseif(($column.htmlType == "select" || $column.htmlType == "radio") && $dictType)
      <el-form-item label="${comment}" prop="${column.javaField}">
        <el-select v-model="queryParams.${column.javaField}" placeholder="ŤĮ∑ťÄČśč©${comment}" clearable>
          <el-option label="ŤĮ∑ťÄČśč©Ś≠óŚÖłÁĒüśąź" value="" />
        </el-select>
      </el-form-item>
#elseif($column.htmlType == "datetime" && $column.queryType != "BETWEEN")
      <el-form-item label="${comment}" prop="${column.javaField}">
        <el-date-picker clearable
          v-model="queryParams.${column.javaField}"
          type="date"
          value-format="yyyy-MM-dd"
          placeholder="ťÄČśč©${comment}">
        </el-date-picker>
      </el-form-item>
#elseif($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
      <el-form-item label="${comment}">
        <el-date-picker
          v-model="daterange${AttrName}"
          style="width: 240px"
          value-format="yyyy-MM-dd"
          type="daterange"
          range-separator="-"
          start-placeholder="ŚľÄŚßčśó•śúü"
          end-placeholder="ÁĽďśĚüśó•śúü"
        ></el-date-picker>
      </el-form-item>
#end
#end
#end
      <el-form-item>
	    <el-button type="primary" icon="el-icon-search" size="mini" @click="handleQuery">śźúÁīĘ</el-button>
        <el-button icon="el-icon-refresh" size="mini" @click="resetQuery">ťáćÁĹģ</el-button>
      </el-form-item>
    </el-form>

    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button
          type="primary"
          plain
          icon="el-icon-plus"
          size="mini"
          @click="handleAdd"
          v-hasPermi="['${permissionPrefix}:add']"
        >śĖįŚĘě</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="info"
          plain
          icon="el-icon-sort"
          size="mini"
          @click="toggleExpandAll"
        >ŚĪēŚľÄ/śäėŚŹ†</el-button>
      </el-col>
      <right-toolbar :showSearch.sync="showSearch" @queryTable="getList"></right-toolbar>
    </el-row>

    <el-table
      v-if="refreshTable"
      v-loading="loading"
      :data="${businessName}List"
      row-key="${treeCode}"
      :default-expand-all="isExpandAll"
      :tree-props="{children: 'children', hasChildren: 'hasChildren'}"
    >
      <el-table-column label="ŚļŹŚŹ∑" align="center" width="50">
        <template slot-scope="scope">
          <span>{{ scope.$index + 1 }}</span>
        </template>
      </el-table-column>
#foreach($column in $columns)
#set($javaField=$column.javaField)
#set($parentheseIndex=$column.columnComment.indexOf("Ôľą"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#if($column.pk)
#elseif($column.list && $column.htmlType == "datetime")
      <el-table-column label="${comment}" align="center" prop="${javaField}" width="180">
        <template slot-scope="scope">
          <span>{{ parseTime(scope.row.${javaField}, '{y}-{m}-{d}') }}</span>
        </template>
      </el-table-column>
#elseif($column.list && $column.htmlType == "imageUpload")
      <el-table-column label="${comment}" align="center" prop="${javaField}" width="100">
        <template slot-scope="scope">
          <image-preview :src="scope.row.${javaField}" :width="50" :height="50"/>
        </template>
      </el-table-column>
#elseif($column.list && "" != $column.dictType)
      <el-table-column label="${comment}" align="center" prop="${javaField}">
        <template slot-scope="scope">
#if($column.htmlType == "checkbox")
          <dict-tag :options="dict.type.${column.dictType}" :value="scope.row.${javaField} ? scope.row.${javaField}.split(',') : []"/>
#else
          <dict-tag :options="dict.type.${column.dictType}" :value="scope.row.${javaField}"/>
#end
        </template>
      </el-table-column>
#elseif($column.list && "" != $javaField)
#if(${foreach.index} == 1)
      <el-table-column label="${comment}" prop="${javaField}" />
#else
      <el-table-column label="${comment}" align="center" prop="${javaField}" />
#end
#end
#end
      <el-table-column label="śďćšĹú" align="center" class-name="small-padding fixed-width">
        <template slot-scope="scope">
#if($genView)
          <el-button
            size="mini"
            type="text"
            icon="el-icon-view"
            @click="handleViewData(scope.row)"
            v-hasPermi="['${permissionPrefix}:query']"
          >ŤĮ¶śÉÖ</el-button>
#end
          <el-button
            size="mini"
            type="text"
            icon="el-icon-edit"
            @click="handleUpdate(scope.row)"
            v-hasPermi="['${permissionPrefix}:edit']"
          >šŅģśĒĻ</el-button>
          <el-button
            size="mini"
            type="text"
            icon="el-icon-plus"
            @click="handleAdd(scope.row)"
            v-hasPermi="['${permissionPrefix}:add']"
          >śĖįŚĘě</el-button>
          <el-button
            size="mini"
            type="text"
            icon="el-icon-delete"
            @click="handleDelete(scope.row)"
            v-hasPermi="['${permissionPrefix}:remove']"
          >Śą†ťô§</el-button>
        </template>
      </el-table-column>
    </el-table>

#if($genView)
    <!-- ${functionName}ŤĮ¶śÉÖśäĹŚĪČ -->
    <${businessName}-view-drawer ref="${businessName}ViewRef" />
#end
    <!-- ś∑ĽŚä†śąĖšŅģśĒĻ${functionName}ŚĮĻŤĮĚś°Ü -->
#if($table.formColNum == 2)
#set($dialogWidth = "800px")
#elseif($table.formColNum == 3)
#set($dialogWidth = "1100px")
#else
#set($dialogWidth = "500px")
#end
    <el-dialog :title="title" :visible.sync="open" width="${dialogWidth}" append-to-body>
      <el-form ref="form" :model="form" :rules="rules" label-width="100px">
        <el-row>
#foreach($column in $columns)
#set($field=$column.javaField)
#if($column.insert && !$column.pk)
#if(($column.usableColumn) || (!$column.superColumn))
#set($parentheseIndex=$column.columnComment.indexOf("Ôľą"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#set($dictType=$column.dictType)
#if("" != $treeParentCode && $column.javaField == $treeParentCode)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${treeParentCode}">
              <treeselect v-model="form.${treeParentCode}" :options="${businessName}Options" :normalizer="normalizer" placeholder="ŤĮ∑ťÄČśč©${comment}" />
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "input")
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-input v-model="form.${field}" placeholder="ŤĮ∑ŤĺďŚÖ•${comment}" />
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "imageUpload")
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <image-upload v-model="form.${field}"/>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "fileUpload")
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <file-upload v-model="form.${field}"/>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "editor")
          <el-col :span="24">
            <el-form-item label="${comment}">
              <editor v-model="form.${field}" :min-height="192"/>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "select" && "" != $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-select v-model="form.${field}" placeholder="ŤĮ∑ťÄČśč©${comment}">
                <el-option
                  v-for="dict in dict.type.${dictType}"
                  :key="dict.value"
                  :label="dict.label"
#if($column.javaType == "Integer" || $column.javaType == "Long")
                  :value="parseInt(dict.value)"
#else
                  :value="dict.value"
#end
                ></el-option>
              </el-select>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "select" && $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-select v-model="form.${field}" placeholder="ŤĮ∑ťÄČśč©${comment}">
                <el-option label="ŤĮ∑ťÄČśč©Ś≠óŚÖłÁĒüśąź" value="" />
              </el-select>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "checkbox" && "" != $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-checkbox-group v-model="form.${field}">
                <el-checkbox
                  v-for="dict in dict.type.${dictType}"
                  :key="dict.value"
                  :label="dict.value">
                  {{dict.label}}
                </el-checkbox>
              </el-checkbox-group>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "checkbox" && $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-checkbox-group v-model="form.${field}">
                <el-checkbox>ŤĮ∑ťÄČśč©Ś≠óŚÖłÁĒüśąź</el-checkbox>
              </el-checkbox-group>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "radio" && "" != $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-radio-group v-model="form.${field}">
                <el-radio
                  v-for="dict in dict.type.${dictType}"
                  :key="dict.value"
#if($column.javaType == "Integer" || $column.javaType == "Long")
                  :label="parseInt(dict.value)"
#else
                  :label="dict.value"
#end
                >{{dict.label}}</el-radio>
              </el-radio-group>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "radio" && $dictType)
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-radio-group v-model="form.${field}">
                <el-radio label="1">ŤĮ∑ťÄČśč©Ś≠óŚÖłÁĒüśąź</el-radio>
              </el-radio-group>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "datetime")
          <el-col :span="${colSpan}">
            <el-form-item label="${comment}" prop="${field}">
              <el-date-picker clearable
                v-model="form.${field}"
                type="date"
                value-format="yyyy-MM-dd"
                placeholder="ťÄČśč©${comment}">
              </el-date-picker>
            </el-form-item>
          </el-col>
#elseif($column.htmlType == "textarea")
          <el-col :span="24">
            <el-form-item label="${comment}" prop="${field}">
              <el-input v-model="form.${field}" type="textarea" placeholder="ŤĮ∑ŤĺďŚÖ•ŚÜÖŚģĻ" />
            </el-form-item>
          </el-col>
#end
#end
#end
#end
        </el-row>
      </el-form>
      <div slot="footer" class="dialog-footer">
        <el-button type="primary" @click="submitForm">Á°ģ Śģö</el-button>
        <el-button @click="cancel">ŚŹĖ ś∂ą</el-button>
      </div>
    </el-dialog>
  </div>
</template>

<script>
import { list${BusinessName}, get${BusinessName}, del${BusinessName}, add${BusinessName}, update${BusinessName} } from "@/api/${moduleName}/${businessName}"
#if($genView)
import ${BusinessName}ViewDrawer from "./view"
#end
import Treeselect from "@riophae/vue-treeselect"
import "@riophae/vue-treeselect/dist/vue-treeselect.css"

export default {
  name: "${BusinessName}",
#if(${dicts} != '')
  dicts: [${dicts}],
#end
  components: {
#if($genView)
    ${BusinessName}ViewDrawer,
#end
    Treeselect
  },
  data() {
    return {
      // ťĀģÁĹ©ŚĪā
      loading: true,
      // śėĺÁ§ļśźúÁīĘśĚ°šĽ∂
      showSearch: true,
      // ${functionName}Ť°®ś†ľśēįśćģ
      ${businessName}List: [],
      // ${functionName}ś†ĎťÄČť°Ļ
      ${businessName}Options: [],
      // ŚľĻŚáļŚĪāś†áťĘė
      title: "",
      // śėĮŚź¶śėĺÁ§ļŚľĻŚáļŚĪā
      open: false,
      // śėĮŚź¶ŚĪēŚľÄÔľĆťĽėŤģ§ŚÖ®ťÉ®ŚĪēŚľÄ
      isExpandAll: true,
      // ťáćśĖįśł≤śüďŤ°®ś†ľÁä∂śÄĀ
      refreshTable: true,
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      // $commentśó∂ťóīŤĆÉŚõī
      daterange${AttrName}: [],
#end
#end
      // śü•ŤĮĘŚŹāśēį
      queryParams: {
#foreach ($column in $columns)
#if($column.query)
        $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
      },
      // Ť°®ŚćēŚŹāśēį
      form: {},
      // Ť°®Śćēś†°ť™Ć
      rules: {
#foreach ($column in $columns)
#if($column.required)
#set($parentheseIndex=$column.columnComment.indexOf("Ôľą"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
        $column.javaField: [
          { required: true, message: "$commentšłćŤÉĹšłļÁ©ļ", trigger: #if($column.htmlType == "select" || $column.htmlType == "radio")"change"#else"blur"#end }
        ]#if($foreach.count != $columns.size()),#end
#end
#end
      }
    }
  },
  created() {
    this.getList()
  },
  methods: {
    /** śü•ŤĮĘ${functionName}ŚąóŤ°® */
    getList() {
      this.loading = true
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
      this.queryParams.params = {}
#break
#end
#end
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      if (null != this.daterange${AttrName} && '' != this.daterange${AttrName}) {
        this.queryParams.params["begin${AttrName}"] = this.daterange${AttrName}[0]
        this.queryParams.params["end${AttrName}"] = this.daterange${AttrName}[1]
      }
#end
#end
      list${BusinessName}(this.queryParams).then(response => {
        this.${businessName}List = this.handleTree(response.data, "${treeCode}", "${treeParentCode}")
        this.loading = false
      })
    },
    /** ŤĹ¨śćĘ${functionName}śēįśćģÁĽďśěĄ */
    normalizer(node) {
      if (node.children && !node.children.length) {
        delete node.children
      }
      return {
        id: node.${treeCode},
        label: node.${treeName},
        children: node.children
      }
    },
	/** śü•ŤĮĘ${functionName}šłčśčČś†ĎÁĽďśěĄ */
    getTreeselect() {
      list${BusinessName}().then(response => {
        this.${businessName}Options = []
        const data = { ${treeCode}: 0, ${treeName}: 'ť°∂ÁļßŤäāÁāĻ', children: [] }
        data.children = this.handleTree(response.data, "${treeCode}", "${treeParentCode}")
        this.${businessName}Options.push(data)
      })
    },
    // ŚŹĖś∂ąśĆČťíģ
    cancel() {
      this.open = false
      this.reset()
    },
    // Ť°®ŚćēťáćÁĹģ
    reset() {
      this.form = {
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
        $column.javaField: []#if($foreach.count != $columns.size()),#end
#else
        $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
      }
      this.resetForm("form")
    },
    /** śźúÁīĘśĆČťíģśďćšĹú */
    handleQuery() {
      this.getList()
    },
    /** ťáćÁĹģśĆČťíģśďćšĹú */
    resetQuery() {
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      this.daterange${AttrName} = []
#end
#end
      this.resetForm("queryForm")
      this.handleQuery()
    },
    /** śĖįŚĘěśĆČťíģśďćšĹú */
    handleAdd(row) {
      this.reset()
      this.getTreeselect()
      if (row != null && row.${treeCode}) {
        this.form.${treeParentCode} = row.${treeCode}
      } else {
        this.form.${treeParentCode} = 0
      }
      this.open = true
      this.title = "ś∑ĽŚä†${functionName}"
    },
    /** ŚĪēŚľÄ/śäėŚŹ†śďćšĹú */
    toggleExpandAll() {
      this.refreshTable = false
      this.isExpandAll = !this.isExpandAll
      this.$nextTick(() => {
        this.refreshTable = true
      })
    },
#if($genView)
    /** ŤĮ¶śÉÖśĆČťíģśďćšĹú */
    handleViewData(row) {
      this.#[[$]]#refs["${businessName}ViewRef"].open(row.${pkColumn.javaField})
    },
#end
    /** šŅģśĒĻśĆČťíģśďćšĹú */
    handleUpdate(row) {
      this.reset()
      this.getTreeselect()
      if (row != null) {
        this.form.${treeParentCode} = row.${treeParentCode}
      }
      get${BusinessName}(row.${pkColumn.javaField}).then(response => {
        this.form = response.data
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
        this.form.$column.javaField = this.form.${column.javaField}.split(",")
#end
#end
        this.open = true
        this.title = "šŅģśĒĻ${functionName}"
      })
    },
    /** śŹźšļ§śĆČťíģ */
    submitForm() {
      this.#[[$]]#refs["form"].validate(valid => {
        if (valid) {
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
          this.form.$column.javaField = this.form.${column.javaField}.join(",")
#end
#end
          if (this.form.${pkColumn.javaField} != null) {
            update${BusinessName}(this.form).then(response => {
              this.#[[$modal]]#.msgSuccess("šŅģśĒĻśąźŚäü")
              this.open = false
              this.getList()
            })
          } else {
            add${BusinessName}(this.form).then(response => {
              this.#[[$modal]]#.msgSuccess("śĖįŚĘěśąźŚäü")
              this.open = false
              this.getList()
            })
          }
        }
      })
    },
    /** Śą†ťô§śĆČťíģśďćšĹú */
    handleDelete(row) {
      this.#[[$modal]]#.confirm('śėĮŚź¶Á°ģŤģ§Śą†ťô§${functionName}ÁľĖŚŹ∑šłļ"' + row.${pkColumn.javaField} + '"ÁöĄśēįśćģť°ĻÔľü').then(function() {
        return del${BusinessName}(row.${pkColumn.javaField})
      }).then(() => {
        this.getList()
        this.#[[$modal]]#.msgSuccess("Śą†ťô§śąźŚäü")
      }).catch(() => {})
    }
  }
}
</script>

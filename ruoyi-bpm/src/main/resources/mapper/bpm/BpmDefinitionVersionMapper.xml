<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmDefinitionVersionMapper">

    <resultMap type="BpmDefinitionVersion" id="BpmDefinitionVersionResult">
        <id     property="versionId"           column="version_id"            />
        <result property="definitionId"        column="definition_id"         />
        <result property="versionNo"           column="version_no"            />
        <result property="deploymentId"        column="deployment_id"         />
        <result property="processDefinitionId" column="process_definition_id" />
        <result property="modelXml"            column="model_xml"             />
        <result property="status"              column="status"                />
        <result property="createBy"            column="create_by"             />
        <result property="createTime"          column="create_time"           />
        <result property="remark"              column="remark"                />
    </resultMap>

    <sql id="selectBpmDefinitionVersionVo">
        select version_id, definition_id, version_no, deployment_id, process_definition_id, model_xml, status, create_by, create_time, remark from bpm_definition_version
    </sql>

    <select id="selectBpmDefinitionVersionById" parameterType="Long" resultMap="BpmDefinitionVersionResult">
        <include refid="selectBpmDefinitionVersionVo"/>
        where version_id = #{versionId}
    </select>

    <select id="selectLatestVersionByDefinitionId" parameterType="Long" resultMap="BpmDefinitionVersionResult">
        <include refid="selectBpmDefinitionVersionVo"/>
        where definition_id = #{definitionId}
        order by version_no desc
        limit 1
    </select>

    <select id="selectBpmDefinitionVersionList" parameterType="BpmDefinitionVersion" resultMap="BpmDefinitionVersionResult">
        <include refid="selectBpmDefinitionVersionVo"/>
        <where>
            <if test="definitionId != null">
                AND definition_id = #{definitionId}
            </if>
            <if test="versionNo != null">
                AND version_no = #{versionNo}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by version_no desc
    </select>

    <insert id="insertBpmDefinitionVersion" parameterType="BpmDefinitionVersion" useGeneratedKeys="true" keyProperty="versionId">
        insert into bpm_definition_version (
            <if test="definitionId != null">definition_id,</if>
            <if test="versionNo != null">version_no,</if>
            <if test="deploymentId != null and deploymentId != ''">deployment_id,</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">process_definition_id,</if>
            <if test="modelXml != null and modelXml != ''">model_xml,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="definitionId != null">#{definitionId},</if>
            <if test="versionNo != null">#{versionNo},</if>
            <if test="deploymentId != null and deploymentId != ''">#{deploymentId},</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">#{processDefinitionId},</if>
            <if test="modelXml != null and modelXml != ''">#{modelXml},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmDefinitionVersion" parameterType="BpmDefinitionVersion">
        update bpm_definition_version
        <set>
            <if test="definitionId != null">definition_id = #{definitionId},</if>
            <if test="versionNo != null">version_no = #{versionNo},</if>
            <if test="deploymentId != null">deployment_id = #{deploymentId},</if>
            <if test="processDefinitionId != null">process_definition_id = #{processDefinitionId},</if>
            <if test="modelXml != null">model_xml = #{modelXml},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where version_id = #{versionId}
    </update>

    <delete id="deleteBpmDefinitionVersionById" parameterType="Long">
        delete from bpm_definition_version where version_id = #{versionId}
    </delete>

    <delete id="deleteBpmDefinitionVersionByIds" parameterType="Long">
        delete from bpm_definition_version where version_id in
        <foreach item="versionId" collection="array" open="(" separator="," close=")">
            #{versionId}
        </foreach>
    </delete>

</mapper>

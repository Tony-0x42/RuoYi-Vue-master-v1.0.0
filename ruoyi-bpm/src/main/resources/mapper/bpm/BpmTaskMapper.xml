<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmTaskMapper">

    <resultMap type="BpmTask" id="BpmTaskResult">
        <id     property="taskId"           column="task_id"            />
        <result property="instanceId"       column="instance_id"        />
        <result property="flowableTaskId"   column="flowable_task_id"   />
        <result property="nodeName"         column="node_name"          />
        <result property="assigneeUserId"   column="assignee_user_id"   />
        <result property="assigneeUserName" column="assignee_user_name" />
        <result property="status"           column="status"             />
        <result property="comment"          column="comment"            />
        <result property="variables"        column="variables"          />
        <result property="createTime"       column="create_time"        />
        <result property="completeTime"     column="complete_time"      />
        <result property="definitionName"   column="definition_name"    />
        <result property="instanceTitle"    column="instance_title"     />
    </resultMap>

    <sql id="selectBpmTaskVo">
        select t.task_id, t.instance_id, t.flowable_task_id, t.node_name, t.assignee_user_id, t.assignee_user_name, t.status, t.comment, t.variables, t.create_time, t.complete_time,
               d.definition_name, i.title as instance_title
        from bpm_task t
        left join bpm_instance i on t.instance_id = i.instance_id
        left join bpm_definition d on i.definition_id = d.definition_id
    </sql>

    <select id="selectBpmTaskById" parameterType="Long" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        where t.task_id = #{taskId}
    </select>

    <select id="selectTaskById" parameterType="Long" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        where t.task_id = #{taskId}
    </select>

    <select id="selectBpmTaskList" parameterType="BpmTask" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        <where>
            <if test="instanceId != null">
                AND t.instance_id = #{instanceId}
            </if>
            <if test="flowableTaskId != null and flowableTaskId != ''">
                AND t.flowable_task_id = #{flowableTaskId}
            </if>
            <if test="assigneeUserId != null">
                AND t.assignee_user_id = #{assigneeUserId}
            </if>
            <if test="status != null and status != ''">
                AND t.status = #{status}
            </if>
        </where>
        order by t.create_time desc
    </select>

    <select id="selectTasksByInstanceId" parameterType="Long" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        where t.instance_id = #{instanceId}
        order by t.create_time
    </select>

    <select id="selectTodoList" parameterType="BpmTask" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        where t.status = '0'
        <if test="assigneeUserId != null">
            AND t.assignee_user_id = #{assigneeUserId}
        </if>
        <if test="instanceId != null">
            AND t.instance_id = #{instanceId}
        </if>
        order by t.create_time desc
    </select>

    <select id="selectDoneList" parameterType="BpmTask" resultMap="BpmTaskResult">
        <include refid="selectBpmTaskVo"/>
        where t.status in ('1', '2', '3')
        <if test="assigneeUserId != null">
            AND t.assignee_user_id = #{assigneeUserId}
        </if>
        <if test="instanceId != null">
            AND t.instance_id = #{instanceId}
        </if>
        order by t.complete_time desc
    </select>

    <insert id="insertBpmTask" parameterType="BpmTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into bpm_task (
            <if test="instanceId != null">instance_id,</if>
            <if test="flowableTaskId != null and flowableTaskId != ''">flowable_task_id,</if>
            <if test="nodeName != null and nodeName != ''">node_name,</if>
            <if test="assigneeUserId != null">assignee_user_id,</if>
            <if test="assigneeUserName != null and assigneeUserName != ''">assignee_user_name,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="comment != null and comment != ''">comment,</if>
            <if test="variables != null and variables != ''">variables,</if>
            <if test="completeTime != null">complete_time,</if>
            create_time
        )values(
            <if test="instanceId != null">#{instanceId},</if>
            <if test="flowableTaskId != null and flowableTaskId != ''">#{flowableTaskId},</if>
            <if test="nodeName != null and nodeName != ''">#{nodeName},</if>
            <if test="assigneeUserId != null">#{assigneeUserId},</if>
            <if test="assigneeUserName != null and assigneeUserName != ''">#{assigneeUserName},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="comment != null and comment != ''">#{comment},</if>
            <if test="variables != null and variables != ''">#{variables},</if>
            <if test="completeTime != null">#{completeTime},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmTask" parameterType="BpmTask">
        update bpm_task
        <set>
            <if test="instanceId != null">instance_id = #{instanceId},</if>
            <if test="flowableTaskId != null">flowable_task_id = #{flowableTaskId},</if>
            <if test="nodeName != null and nodeName != ''">node_name = #{nodeName},</if>
            <if test="assigneeUserId != null">assignee_user_id = #{assigneeUserId},</if>
            <if test="assigneeUserName != null and assigneeUserName != ''">assignee_user_name = #{assigneeUserName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="comment != null">comment = #{comment},</if>
            <if test="variables != null">variables = #{variables},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
        </set>
        where task_id = #{taskId}
    </update>

    <delete id="deleteBpmTaskById" parameterType="Long">
        delete from bpm_task where task_id = #{taskId}
    </delete>

    <delete id="deleteBpmTaskByIds" parameterType="Long">
        delete from bpm_task where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmDefinitionMapper">

    <resultMap type="BpmDefinition" id="BpmDefinitionResult">
        <id     property="definitionId"       column="definition_id"        />
        <result property="categoryId"         column="category_id"          />
        <result property="categoryName"       column="category_name"        />
        <result property="definitionName"     column="definition_name"      />
        <result property="definitionCode"     column="definition_code"      />
        <result property="version"            column="version"              />
        <result property="deploymentId"       column="deployment_id"        />
        <result property="processDefinitionId" column="process_definition_id" />
        <result property="modelXml"           column="model_xml"            />
        <result property="status"             column="status"               />
        <result property="createBy"           column="create_by"            />
        <result property="createTime"         column="create_time"          />
        <result property="updateBy"           column="update_by"            />
        <result property="updateTime"         column="update_time"          />
        <result property="remark"             column="remark"               />
    </resultMap>

    <sql id="selectBpmDefinitionVo">
        select d.definition_id, d.category_id, c.category_name, d.definition_name, d.definition_code, d.version, d.deployment_id, d.process_definition_id, d.model_xml, d.status, d.create_by, d.create_time, d.update_by, d.update_time, d.remark
        from bpm_definition d
        left join bpm_category c on d.category_id = c.category_id
    </sql>

    <select id="selectBpmDefinitionById" parameterType="Long" resultMap="BpmDefinitionResult">
        <include refid="selectBpmDefinitionVo"/>
        where definition_id = #{definitionId}
    </select>

    <select id="selectBpmDefinitionList" parameterType="BpmDefinition" resultMap="BpmDefinitionResult">
        <include refid="selectBpmDefinitionVo"/>
        <where>
            <if test="categoryId != null and params.categoryIds != null and params.categoryIds.size > 0">
                AND d.category_id in
                <foreach collection="params.categoryIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="definitionName != null and definitionName != ''">
                AND d.definition_name like concat('%', #{definitionName}, '%')
            </if>
            <if test="definitionCode != null and definitionCode != ''">
                AND d.definition_code like concat('%', #{definitionCode}, '%')
            </if>
            <if test="status != null and status != ''">
                AND d.status = #{status}
            </if>
            <if test="processDefinitionId != null and processDefinitionId != ''">
                AND d.process_definition_id = #{processDefinitionId}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertBpmDefinition" parameterType="BpmDefinition">
        insert into bpm_definition (
            <if test="categoryId != null">category_id,</if>
            <if test="definitionName != null and definitionName != ''">definition_name,</if>
            <if test="definitionCode != null and definitionCode != ''">definition_code,</if>
            <if test="version != null">version,</if>
            <if test="deploymentId != null and deploymentId != ''">deployment_id,</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">process_definition_id,</if>
            <if test="modelXml != null and modelXml != ''">model_xml,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="categoryId != null">#{categoryId},</if>
            <if test="definitionName != null and definitionName != ''">#{definitionName},</if>
            <if test="definitionCode != null and definitionCode != ''">#{definitionCode},</if>
            <if test="version != null">#{version},</if>
            <if test="deploymentId != null and deploymentId != ''">#{deploymentId},</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">#{processDefinitionId},</if>
            <if test="modelXml != null and modelXml != ''">#{modelXml},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmDefinition" parameterType="BpmDefinition">
        update bpm_definition
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="definitionName != null and definitionName != ''">definition_name = #{definitionName},</if>
            <if test="definitionCode != null and definitionCode != ''">definition_code = #{definitionCode},</if>
            <if test="version != null">version = #{version},</if>
            <if test="deploymentId != null">deployment_id = #{deploymentId},</if>
            <if test="processDefinitionId != null">process_definition_id = #{processDefinitionId},</if>
            <if test="modelXml != null">model_xml = #{modelXml},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where definition_id = #{definitionId}
    </update>

    <delete id="deleteBpmDefinitionById" parameterType="Long">
        delete from bpm_definition where definition_id = #{definitionId}
    </delete>

    <delete id="deleteBpmDefinitionByIds" parameterType="Long">
        delete from bpm_definition where definition_id in
        <foreach item="definitionId" collection="array" open="(" separator="," close=")">
            #{definitionId}
        </foreach>
    </delete>

    <select id="selectDefinitionCountByCategoryId" parameterType="Long" resultType="int">
        select count(1) from bpm_definition where category_id = #{categoryId}
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmWorkbenchComponentMapper">

    <resultMap type="BpmWorkbenchComponent" id="BpmWorkbenchComponentResult">
        <id     property="componentId"   column="component_id"   />
        <result property="componentName" column="component_name" />
        <result property="componentLabel" column="component_label" />
        <result property="componentDesc" column="component_desc" />
        <result property="componentPath" column="component_path" />
        <result property="icon"          column="icon"           />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectBpmWorkbenchComponentVo">
        select component_id, component_name, component_label, component_desc, component_path, icon, status, create_by, create_time, update_by, update_time, remark from bpm_workbench_component
    </sql>

    <select id="selectBpmWorkbenchComponentById" parameterType="Long" resultMap="BpmWorkbenchComponentResult">
        <include refid="selectBpmWorkbenchComponentVo"/>
        where component_id = #{componentId}
    </select>

    <select id="selectBpmWorkbenchComponentByName" parameterType="String" resultMap="BpmWorkbenchComponentResult">
        <include refid="selectBpmWorkbenchComponentVo"/>
        where component_name = #{componentName}
    </select>

    <select id="selectBpmWorkbenchComponentList" parameterType="BpmWorkbenchComponent" resultMap="BpmWorkbenchComponentResult">
        <include refid="selectBpmWorkbenchComponentVo"/>
        <where>
            <if test="componentName != null and componentName != ''">
                AND component_name like concat('%', #{componentName}, '%')
            </if>
            <if test="componentLabel != null and componentLabel != ''">
                AND component_label like concat('%', #{componentLabel}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <select id="selectUserAvailableComponents" parameterType="Long" resultMap="BpmWorkbenchComponentResult">
        select c.component_id, c.component_name, c.component_label, c.component_desc, c.component_path, c.icon, c.status
        from bpm_workbench_component c
        where c.status = '0'
          and (
              not exists (select 1 from bpm_workbench_component_scope s where s.component_id = c.component_id)
              or exists (
                  select 1 from bpm_workbench_component_scope s
                  where s.component_id = c.component_id
                    and (
                        (s.scope_type = '1' and s.scope_target_id in (select role_id from sys_user_role where user_id = #{userId}))
                        or (s.scope_type = '2' and s.scope_target_id in (
                            select dept_id from sys_user where user_id = #{userId}
                            union
                            select ancestors from sys_user u left join sys_dept d on u.dept_id = d.dept_id where u.user_id = #{userId}
                        ))
                        or (s.scope_type = '3' and s.scope_target_id = #{userId})
                    )
              )
          )
    </select>

    <insert id="insertBpmWorkbenchComponent" parameterType="BpmWorkbenchComponent" useGeneratedKeys="true" keyProperty="componentId">
        insert into bpm_workbench_component (
            <if test="componentName != null and componentName != ''">component_name,</if>
            <if test="componentLabel != null and componentLabel != ''">component_label,</if>
            <if test="componentDesc != null and componentDesc != ''">component_desc,</if>
            <if test="componentPath != null and componentPath != ''">component_path,</if>
            <if test="icon != null and icon != ''">icon,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="componentName != null and componentName != ''">#{componentName},</if>
            <if test="componentLabel != null and componentLabel != ''">#{componentLabel},</if>
            <if test="componentDesc != null and componentDesc != ''">#{componentDesc},</if>
            <if test="componentPath != null and componentPath != ''">#{componentPath},</if>
            <if test="icon != null and icon != ''">#{icon},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmWorkbenchComponent" parameterType="BpmWorkbenchComponent">
        update bpm_workbench_component
        <set>
            <if test="componentName != null and componentName != ''">component_name = #{componentName},</if>
            <if test="componentLabel != null and componentLabel != ''">component_label = #{componentLabel},</if>
            <if test="componentDesc != null">component_desc = #{componentDesc},</if>
            <if test="componentPath != null and componentPath != ''">component_path = #{componentPath},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where component_id = #{componentId}
    </update>

    <delete id="deleteBpmWorkbenchComponentById" parameterType="Long">
        delete from bpm_workbench_component where component_id = #{componentId}
    </delete>

    <delete id="deleteBpmWorkbenchComponentByIds" parameterType="Long">
        delete from bpm_workbench_component where component_id in
        <foreach item="componentId" collection="array" open="(" separator="," close=")">
            #{componentId}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmInstanceMapper">

    <resultMap type="BpmInstance" id="BpmInstanceResult">
        <id     property="instanceId"        column="instance_id"         />
        <result property="definitionId"      column="definition_id"       />
        <result property="processInstanceId" column="process_instance_id" />
        <result property="processDefinitionId" column="process_definition_id" />
        <result property="businessKey"       column="business_key"        />
        <result property="title"             column="title"               />
        <result property="status"            column="status"              />
        <result property="variables"         column="variables"           />
        <result property="startUserId"       column="start_user_id"       />
        <result property="startUserName"     column="start_user_name"     />
        <result property="startTime"         column="start_time"          />
        <result property="endTime"           column="end_time"            />
        <result property="createBy"          column="create_by"           />
        <result property="createTime"        column="create_time"         />
        <result property="updateBy"          column="update_by"           />
        <result property="updateTime"        column="update_time"         />
        <result property="remark"            column="remark"              />
        <result property="definitionName"    column="definition_name"     />
        <result property="categoryName"      column="category_name"       />
        <result property="currentNodeName"   column="current_node_name"   />
    </resultMap>

    <sql id="selectBpmInstanceVo">
        select i.instance_id, i.definition_id, i.process_instance_id, i.process_definition_id, i.business_key, i.title, i.status, i.variables, i.start_user_id, i.start_user_name, i.start_time, i.end_time, i.create_by, i.create_time, i.update_by, i.update_time, i.remark,
               d.definition_name, c.category_name
        from bpm_instance i
        left join bpm_definition d on i.definition_id = d.definition_id
        left join bpm_category c on d.category_id = c.category_id
    </sql>

    <select id="selectBpmInstanceById" parameterType="Long" resultMap="BpmInstanceResult">
        <include refid="selectBpmInstanceVo"/>
        where i.instance_id = #{instanceId}
    </select>

    <select id="selectBpmInstanceList" parameterType="BpmInstance" resultMap="BpmInstanceResult">
        <include refid="selectBpmInstanceVo"/>
        <where>
            <if test="definitionId != null">
                AND i.definition_id = #{definitionId}
            </if>
            <if test="businessKey != null and businessKey != ''">
                AND i.business_key like concat('%', #{businessKey}, '%')
            </if>
            <if test="title != null and title != ''">
                AND i.title like concat('%', #{title}, '%')
            </if>
            <if test="status != null and status != ''">
                AND i.status = #{status}
            </if>
            <if test="startUserId != null">
                AND i.start_user_id = #{startUserId}
            </if>
            <if test="startUserName != null and startUserName != ''">
                AND i.start_user_name like concat('%', #{startUserName}, '%')
            </if>
        </where>
        order by i.create_time desc
    </select>

    <insert id="insertBpmInstance" parameterType="BpmInstance" useGeneratedKeys="true" keyProperty="instanceId">
        insert into bpm_instance (
            <if test="definitionId != null">definition_id,</if>
            <if test="processInstanceId != null and processInstanceId != ''">process_instance_id,</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">process_definition_id,</if>
            <if test="businessKey != null and businessKey != ''">business_key,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="variables != null and variables != ''">variables,</if>
            <if test="startUserId != null">start_user_id,</if>
            <if test="startUserName != null and startUserName != ''">start_user_name,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="definitionId != null">#{definitionId},</if>
            <if test="processInstanceId != null and processInstanceId != ''">#{processInstanceId},</if>
            <if test="processDefinitionId != null and processDefinitionId != ''">#{processDefinitionId},</if>
            <if test="businessKey != null and businessKey != ''">#{businessKey},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="variables != null and variables != ''">#{variables},</if>
            <if test="startUserId != null">#{startUserId},</if>
            <if test="startUserName != null and startUserName != ''">#{startUserName},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmInstance" parameterType="BpmInstance">
        update bpm_instance
        <set>
            <if test="definitionId != null">definition_id = #{definitionId},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="processDefinitionId != null">process_definition_id = #{processDefinitionId},</if>
            <if test="businessKey != null and businessKey != ''">business_key = #{businessKey},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="variables != null">variables = #{variables},</if>
            <if test="startUserId != null">start_user_id = #{startUserId},</if>
            <if test="startUserName != null and startUserName != ''">start_user_name = #{startUserName},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where instance_id = #{instanceId}
    </update>

    <delete id="deleteBpmInstanceById" parameterType="Long">
        delete from bpm_instance where instance_id = #{instanceId}
    </delete>

    <delete id="deleteBpmInstanceByIds" parameterType="Long">
        delete from bpm_instance where instance_id in
        <foreach item="instanceId" collection="array" open="(" separator="," close=")">
            #{instanceId}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.mapper.BpmCategoryMapper">

    <resultMap type="BpmCategory" id="BpmCategoryResult">
        <id     property="categoryId"   column="category_id"    />
        <result property="parentId"     column="parent_id"      />
        <result property="ancestors"    column="ancestors"      />
        <result property="categoryName" column="category_name"  />
        <result property="categoryCode" column="category_code"  />
        <result property="orderNum"     column="order_num"      />
        <result property="status"       column="status"         />
        <result property="parentName"   column="parent_name"    />
        <result property="createBy"     column="create_by"      />
        <result property="createTime"   column="create_time"    />
        <result property="updateBy"     column="update_by"      />
        <result property="updateTime"   column="update_time"    />
        <result property="remark"       column="remark"         />
    </resultMap>

    <sql id="selectBpmCategoryVo">
        select category_id, parent_id, ancestors, category_name, category_code, order_num, status, create_by, create_time, update_by, update_time, remark from bpm_category
    </sql>

    <select id="selectBpmCategoryById" parameterType="Long" resultMap="BpmCategoryResult">
        select category_id, parent_id, ancestors, category_name, category_code, order_num, status, create_by, create_time, update_by, update_time, remark,
            (select category_name from bpm_category where category_id = c.parent_id) parent_name
        from bpm_category c
        where category_id = #{categoryId}
    </select>

    <select id="selectBpmCategoryList" parameterType="BpmCategory" resultMap="BpmCategoryResult">
        <include refid="selectBpmCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                AND category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="categoryCode != null and categoryCode != ''">
                AND category_code like concat('%', #{categoryCode}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="parentId != null and parentId != 0">
                AND parent_id = #{parentId}
            </if>
        </where>
        order by parent_id, order_num
    </select>

    <select id="selectBpmCategoryTreeList" parameterType="BpmCategory" resultMap="BpmCategoryResult">
        <include refid="selectBpmCategoryVo"/>
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by parent_id, order_num
    </select>

    <select id="selectCategoryIdsByAncestorId" parameterType="Long" resultType="Long">
        select category_id from bpm_category where find_in_set(#{categoryId}, ancestors)
    </select>

    <select id="hasChildByCategoryId" parameterType="Long" resultType="int">
        select count(1) from bpm_category where parent_id = #{categoryId} limit 1
    </select>

    <select id="selectChildrenCategoryById" parameterType="Long" resultMap="BpmCategoryResult">
        select * from bpm_category where find_in_set(#{categoryId}, ancestors)
    </select>

    <insert id="insertBpmCategory" parameterType="BpmCategory">
        insert into bpm_category (
            <if test="parentId != null and parentId != 0">parent_id,</if>
            <if test="ancestors != null and ancestors != ''">ancestors,</if>
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="parentId != null and parentId != 0">#{parentId},</if>
            <if test="ancestors != null and ancestors != ''">#{ancestors},</if>
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBpmCategory" parameterType="BpmCategory">
        update bpm_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="ancestors != null">ancestors = #{ancestors},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <update id="updateCategoryChildren" parameterType="java.util.List">
        update bpm_category set ancestors =
        <foreach collection="list" item="item" index="index"
            separator=" " open="case category_id" close="end">
            when #{item.categoryId} then #{item.ancestors}
        </foreach>
        where category_id in
        <foreach collection="list" item="item" index="index"
            separator="," open="(" close=")">
            #{item.categoryId}
        </foreach>
    </update>

    <delete id="deleteBpmCategoryById" parameterType="Long">
        delete from bpm_category where category_id = #{categoryId}
    </delete>

    <delete id="deleteBpmCategoryByIds" parameterType="Long">
        delete from bpm_category where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>

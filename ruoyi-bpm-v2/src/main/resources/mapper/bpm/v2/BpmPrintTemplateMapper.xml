<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.v2.mapper.BpmPrintTemplateMapper">

    <resultMap type="com.ruoyi.bpm.v2.domain.BpmPrintTemplate" id="BpmPrintTemplateResult">
        <id property="id" column="id"/>
        <result property="definitionId" column="definition_id"/>
        <result property="versionId" column="version_id"/>
        <result property="name" column="name"/>
        <result property="content" column="content"/>
        <result property="fieldMapping" column="field_mapping"/>
        <result property="pageSetting" column="page_setting"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectBpmPrintTemplateVo">
        select id, definition_id, version_id, name, content, field_mapping, page_setting, tenant_id,
               create_by, create_time, update_by, update_time
        from bpm_print_template
    </sql>

    <select id="selectById" parameterType="Long" resultMap="BpmPrintTemplateResult">
        <include refid="selectBpmPrintTemplateVo"/> where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.bpm.v2.domain.BpmPrintTemplate" resultMap="BpmPrintTemplateResult">
        <include refid="selectBpmPrintTemplateVo"/>
        <where>
            <if test="definitionId != null">and definition_id = #{definitionId}</if>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        </where>
    </select>

    <select id="selectByDefinitionAndVersion" resultMap="BpmPrintTemplateResult">
        <include refid="selectBpmPrintTemplateVo"/>
        where definition_id = #{definitionId}
        <if test="versionId != null">and version_id = #{versionId}</if>
        limit 1
    </select>

    <insert id="insert" parameterType="com.ruoyi.bpm.v2.domain.BpmPrintTemplate" useGeneratedKeys="true" keyProperty="id">
        insert into bpm_print_template
        (definition_id, version_id, name, content, field_mapping, page_setting, tenant_id, create_by, create_time)
        values
        (#{definitionId}, #{versionId}, #{name}, #{content}, #{fieldMapping}, #{pageSetting}, #{tenantId}, #{createBy}, sysdate())
    </insert>

    <update id="update" parameterType="com.ruoyi.bpm.v2.domain.BpmPrintTemplate">
        update bpm_print_template
        <set>
            <if test="definitionId != null">definition_id = #{definitionId},</if>
            <if test="versionId != null">version_id = #{versionId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="content != null">content = #{content},</if>
            <if test="fieldMapping != null">field_mapping = #{fieldMapping},</if>
            <if test="pageSetting != null">page_setting = #{pageSetting},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from bpm_print_template where id = #{id}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.v2.mapper.BpmTaskHistoryMapper">

    <resultMap type="com.ruoyi.bpm.v2.domain.BpmTaskHistory" id="BpmTaskHistoryResult">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="instanceId" column="instance_id"/>
        <result property="nodeId" column="node_id"/>
        <result property="operator" column="operator"/>
        <result property="action" column="action"/>
        <result property="opinion" column="opinion"/>
        <result property="formData" column="form_data"/>
        <result property="operateTime" column="operate_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectBpmTaskHistoryVo">
        select id, task_id, instance_id, node_id, operator, action, opinion, form_data, operate_time, create_time
        from bpm_task_history
    </sql>

    <select id="selectById" parameterType="Long" resultMap="BpmTaskHistoryResult">
        <include refid="selectBpmTaskHistoryVo"/>
        where id = #{id}
    </select>

    <select id="selectByInstanceId" parameterType="String" resultMap="BpmTaskHistoryResult">
        <include refid="selectBpmTaskHistoryVo"/>
        where instance_id = #{instanceId}
        order by operate_time asc, id asc
    </select>

    <select id="selectByOperator" parameterType="Long" resultMap="BpmTaskHistoryResult">
        <include refid="selectBpmTaskHistoryVo"/>
        where operator = #{operator}
        order by operate_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.bpm.v2.domain.BpmTaskHistory" useGeneratedKeys="true" keyProperty="id">
        insert into bpm_task_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null and taskId != ''">task_id,</if>
            <if test="instanceId != null and instanceId != ''">instance_id,</if>
            <if test="nodeId != null and nodeId != ''">node_id,</if>
            <if test="operator != null">operator,</if>
            <if test="action != null and action != ''">action,</if>
            <if test="opinion != null">opinion,</if>
            <if test="formData != null and formData != ''">form_data,</if>
            operate_time,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null and taskId != ''">#{taskId},</if>
            <if test="instanceId != null and instanceId != ''">#{instanceId},</if>
            <if test="nodeId != null and nodeId != ''">#{nodeId},</if>
            <if test="operator != null">#{operator},</if>
            <if test="action != null and action != ''">#{action},</if>
            <if test="opinion != null">#{opinion},</if>
            <if test="formData != null and formData != ''">#{formData},</if>
            sysdate(),
            sysdate()
        </trim>
    </insert>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.v2.mapper.BpmProcessDefinitionMapper">

    <resultMap type="com.ruoyi.bpm.v2.domain.BpmProcessDefinition" id="BpmProcessDefinitionResult">
        <id property="id" column="id"/>
        <result property="processKey" column="process_key"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="latestVersion" column="latest_version"/>
        <result property="status" column="status"/>
        <result property="xml" column="xml"/>
        <result property="extJson" column="ext_json"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectBpmProcessDefinitionVo">
        select id, process_key, name, category_id, tenant_id, latest_version, status, xml, ext_json,
               create_by, create_time, update_by, update_time, remark
        from bpm_process_definition
    </sql>

    <select id="selectById" parameterType="Long" resultMap="BpmProcessDefinitionResult">
        <include refid="selectBpmProcessDefinitionVo"/>
        where id = #{id}
    </select>

    <select id="selectByKeyAndTenant" resultMap="BpmProcessDefinitionResult">
        <include refid="selectBpmProcessDefinitionVo"/>
        where process_key = #{processKey}
        <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        limit 1
    </select>

    <select id="selectList" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessDefinition" resultMap="BpmProcessDefinitionResult">
        <include refid="selectBpmProcessDefinitionVo"/>
        <where>
            <if test="processKey != null and processKey != ''">and process_key = #{processKey}</if>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="categoryId != null">and category_id = #{categoryId}</if>
            <if test="status != null">and status = #{status}</if>
            <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessDefinition" useGeneratedKeys="true" keyProperty="id">
        insert into bpm_process_definition
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="processKey != null and processKey != ''">process_key,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="latestVersion != null and latestVersion != ''">latest_version,</if>
            <if test="status != null">status,</if>
            <if test="xml != null and xml != ''">xml,</if>
            <if test="extJson != null and extJson != ''">ext_json,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="processKey != null and processKey != ''">#{processKey},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="latestVersion != null and latestVersion != ''">#{latestVersion},</if>
            <if test="status != null">#{status},</if>
            <if test="xml != null and xml != ''">#{xml},</if>
            <if test="extJson != null and extJson != ''">#{extJson},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessDefinition">
        update bpm_process_definition
        <set>
            <if test="processKey != null and processKey != ''">process_key = #{processKey},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="latestVersion != null">latest_version = #{latestVersion},</if>
            <if test="status != null">status = #{status},</if>
            <if test="xml != null">xml = #{xml},</if>
            <if test="extJson != null">ext_json = #{extJson},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from bpm_process_definition where id = #{id}
    </delete>

    <delete id="deleteByIds">
        delete from bpm_process_definition where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="checkProcessKeyUnique" resultMap="BpmProcessDefinitionResult">
        <include refid="selectBpmProcessDefinitionVo"/>
        where process_key = #{processKey}
        <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        limit 1
    </select>

</mapper>

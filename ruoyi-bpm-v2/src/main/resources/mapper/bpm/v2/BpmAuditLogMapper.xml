<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.v2.mapper.BpmAuditLogMapper">

    <resultMap type="com.ruoyi.bpm.v2.domain.BpmAuditLog" id="BpmAuditLogResult">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="userId" column="user_id"/>
        <result property="ip" column="ip"/>
        <result property="action" column="action"/>
        <result property="objectType" column="object_type"/>
        <result property="objectId" column="object_id"/>
        <result property="beforeValue" column="before_value"/>
        <result property="afterValue" column="after_value"/>
        <result property="operateTime" column="operate_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectBpmAuditLogVo">
        select id, tenant_id, user_id, ip, action, object_type, object_id, before_value, after_value, operate_time, create_time
        from bpm_audit_log
    </sql>

    <select id="selectById" parameterType="Long" resultMap="BpmAuditLogResult">
        <include refid="selectBpmAuditLogVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.bpm.v2.domain.BpmAuditLog" resultMap="BpmAuditLogResult">
        <include refid="selectBpmAuditLogVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="action != null and action != ''">and action = #{action}</if>
            <if test="objectType != null and objectType != ''">and object_type = #{objectType}</if>
            <if test="objectId != null and objectId != ''">and object_id = #{objectId}</if>
            <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        </where>
        order by operate_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.bpm.v2.domain.BpmAuditLog" useGeneratedKeys="true" keyProperty="id">
        insert into bpm_audit_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tenantId != null">tenant_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="ip != null and ip != ''">ip,</if>
            <if test="action != null and action != ''">action,</if>
            <if test="objectType != null and objectType != ''">object_type,</if>
            <if test="objectId != null and objectId != ''">object_id,</if>
            <if test="beforeValue != null and beforeValue != ''">before_value,</if>
            <if test="afterValue != null and afterValue != ''">after_value,</if>
            operate_time,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tenantId != null">#{tenantId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="ip != null and ip != ''">#{ip},</if>
            <if test="action != null and action != ''">#{action},</if>
            <if test="objectType != null and objectType != ''">#{objectType},</if>
            <if test="objectId != null and objectId != ''">#{objectId},</if>
            <if test="beforeValue != null and beforeValue != ''">#{beforeValue},</if>
            <if test="afterValue != null and afterValue != ''">#{afterValue},</if>
            sysdate(),
            sysdate()
        </trim>
    </insert>

</mapper>

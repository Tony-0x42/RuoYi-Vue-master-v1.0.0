<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bpm.v2.mapper.BpmProcessInstanceMapper">

    <resultMap type="com.ruoyi.bpm.v2.domain.BpmProcessInstance" id="BpmProcessInstanceResult">
        <id property="id" column="id"/>
        <result property="definitionId" column="definition_id"/>
        <result property="versionId" column="version_id"/>
        <result property="businessKey" column="business_key"/>
        <result property="starter" column="starter"/>
        <result property="status" column="status"/>
        <result property="variables" column="variables"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectBpmProcessInstanceVo">
        select id, definition_id, version_id, business_key, starter, status, variables, tenant_id, start_time, end_time,
               create_by, create_time
        from bpm_process_instance
    </sql>

    <select id="selectById" parameterType="String" resultMap="BpmProcessInstanceResult">
        <include refid="selectBpmProcessInstanceVo"/>
        where id = #{id}
    </select>

    <select id="selectList" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessInstance" resultMap="BpmProcessInstanceResult">
        <include refid="selectBpmProcessInstanceVo"/>
        <where>
            <if test="id != null and id != ''">and id = #{id}</if>
            <if test="definitionId != null">and definition_id = #{definitionId}</if>
            <if test="versionId != null">and version_id = #{versionId}</if>
            <if test="businessKey != null and businessKey != ''">and business_key = #{businessKey}</if>
            <if test="starter != null">and starter = #{starter}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        </where>
        order by start_time desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessInstance">
        insert into bpm_process_instance
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null and id != ''">id,</if>
            <if test="definitionId != null">definition_id,</if>
            <if test="versionId != null">version_id,</if>
            <if test="businessKey != null and businessKey != ''">business_key,</if>
            <if test="starter != null">starter,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="variables != null and variables != ''">variables,</if>
            <if test="tenantId != null">tenant_id,</if>
            start_time,
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null and id != ''">#{id},</if>
            <if test="definitionId != null">#{definitionId},</if>
            <if test="versionId != null">#{versionId},</if>
            <if test="businessKey != null and businessKey != ''">#{businessKey},</if>
            <if test="starter != null">#{starter},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="variables != null and variables != ''">#{variables},</if>
            <if test="tenantId != null">#{tenantId},</if>
            sysdate(),
            sysdate()
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.bpm.v2.domain.BpmProcessInstance">
        update bpm_process_instance
        <set>
            <if test="definitionId != null">definition_id = #{definitionId},</if>
            <if test="versionId != null">version_id = #{versionId},</if>
            <if test="businessKey != null and businessKey != ''">business_key = #{businessKey},</if>
            <if test="starter != null">starter = #{starter},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="variables != null">variables = #{variables},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
        </set>
        where id = #{id}
    </update>

    <select id="selectByBusinessKey" resultMap="BpmProcessInstanceResult">
        <include refid="selectBpmProcessInstanceVo"/>
        where business_key = #{businessKey}
        <if test="tenantId != null">and tenant_id = #{tenantId}</if>
        limit 1
    </select>

</mapper>
